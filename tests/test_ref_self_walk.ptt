// Codex review round 2 positive coverage. The receiver walker
// must reject only when rooted at a non-ref parameter. Local
// roots and ref-param roots both legitimately allow ref-self
// method calls through field/index chains.

use std/string
use std/list
use std/map

Counter is { value int }
Holder is { counter Counter }

Counter.bump(self ref Counter) {
  self.value be self.value + 1
}

// Ref-param root — caller acknowledged the mutation.
bump_via_ref_param(h ref Holder) {
  h.counter.bump()
}

test "ref-param root allows nested ref-self call" {
  h is Holder()
  bump_via_ref_param(ref h)
  bump_via_ref_param(ref h)
  assert(h.counter.value eq 2)
}

test "local root allows nested ref-self call" {
  h is Holder()
  h.counter.bump()
  h.counter.bump()
  h.counter.bump()
  assert(h.counter.value eq 3)
}

test "bare ref-self call on local works (control)" {
  c is Counter()
  c.bump()
  assert(c.value eq 1)
}

// Task #142 positive: when `xs` is a `ref` parameter, the
// receiver walker traces through `xs.get(0)` (an alias-returning
// method) and finds the ref param, allowing the call.
bump_first(xs ref List of Counter) {
  xs.get(0).bump()
}

test "ref param allows ref-self call through xs.get(i)" {
  xs is List of Counter
  c is Counter()
  c.value be 5
  xs.push(c)
  bump_first(ref xs)
  bump_first(ref xs)
  assert(xs.get(0).value eq 7)
}

test "local List root allows ref-self call through xs.get(i)" {
  xs is List of Counter
  xs.push(Counter(value is 1))
  xs.get(0).bump()
  xs.get(0).bump()
  assert(xs.get(0).value eq 3)
}

HolderMap is {
  items Map of String, Counter
}

bump_named(m ref Map of String, Counter) {
  m.get("main").bump()
}

bump_map_field(h ref HolderMap) {
  h.items.get("main").bump()
}

test "ref map param allows ref-self call through m.get(k)" {
  m is Map of String, Counter
  m.set("main", Counter(value is 10))
  bump_named(ref m)
  bump_named(ref m)
  assert(m.get("main").value eq 12)
}

test "ref field map root allows ref-self call through h.items.get(k)" {
  h is HolderMap()
  h.items.set("main", Counter(value is 20))
  bump_map_field(ref h)
  assert(h.items.get("main").value eq 21)
}
