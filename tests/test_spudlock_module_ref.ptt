// Regression for spudlock issue #5: `module.func(ref x, ...)`
// was rejected at the call site. Pre-fix, this produced
// "unexpected token in expression"; post-fix, `ref` parses
// and the receiver is mutated just like a non-module-qualified
// call. Codex audit P0-2 (in the same change) added enforcement
// so the call site's `ref` is required to match the parameter.

use std/string
use tests/lib/spudlock_helper

test "module-qualified ref call site parses and mutates" {
  t is Holder(x is 0)
  spudlock_helper.set_value(ref t, 42)
  assert(t.x eq 42)
}
