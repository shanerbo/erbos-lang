// Rotting Oranges tests — solve() comes from
// examples/leetcode/rotting_oranges.ptt.

use leetcode/rotting_oranges

test "rotting oranges basic" {
  assert(rotting_oranges.solve([2,1,1, 1,1,0, 0,1,1], 3, 3) eq 4)
  assert(rotting_oranges.solve([0, 2], 1, 2) eq 0)
  assert(rotting_oranges.solve([2], 1, 1) eq 0)
}

test "rotting oranges unreachable" {
  assert(rotting_oranges.solve([2,1,1, 0,1,1, 1,0,1], 3, 3) eq -1)
  assert(rotting_oranges.solve([1], 1, 1) eq -1)
}

test "rotting oranges multi source" {
  assert(rotting_oranges.solve([2,1,1, 1,1,1, 0,1,2], 3, 3) eq 2)
  assert(rotting_oranges.solve([2,2, 1,1], 2, 2) eq 1)
}
