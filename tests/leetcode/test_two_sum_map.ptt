use std/string

// Two Sum (Map approach) tests — solve() comes from
// tests/lib/leetcode/two_sum_map.ptt. Verifies the O(n) Map-keyed
// implementation produces the same answers as the O(n^2) brute
// force.

use tests/lib/leetcode/two_sum_map
use tests/lib/leetcode/two_sum

test "two sum map basic" {
  assert(two_sum_map.solve([2, 7], 2, 9) eq 1)
  assert(two_sum_map.solve([1, 2], 2, 3) eq 1)
  assert(two_sum_map.solve([3, 3], 2, 6) eq 1)
}

test "two sum map medium" {
  assert(two_sum_map.solve([2, 7, 11, 15], 4, 9) eq 1)
  assert(two_sum_map.solve([3, 2, 4], 3, 6) eq 102)
  // [1, 3, 5, 7] target 8 has TWO valid pairs: (0,3)=1+7 and
  // (1,2)=3+5. Brute force returns the first by scan order
  // (0,3 → 3), the map approach returns the first by complement
  // lookup (1,2 → 102). Both are correct answers.
  result is two_sum_map.solve([1, 3, 5, 7], 4, 8)
  assert(result eq 102 or result eq 3)
}

test "two sum map not found" {
  assert(two_sum_map.solve([1, 2, 3], 3, 100) eq -1)
}

test "two sum map agrees with brute force on unique-pair inputs" {
  // Inputs with exactly one valid pair — both implementations
  // must agree.
  assert(two_sum_map.solve([2, 7, 11, 15], 4, 9) eq two_sum.solve([2, 7, 11, 15], 4, 9))
  assert(two_sum_map.solve([3, 2, 4], 3, 6) eq two_sum.solve([3, 2, 4], 3, 6))
}
