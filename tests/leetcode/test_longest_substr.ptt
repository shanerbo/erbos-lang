use std/string

// Longest Substring Without Repeating Characters tests —
// `longest()` comes from tests/lib/leetcode/longest_substr.ptt
// (the sliding-window version) and
// tests/lib/leetcode/longest_substr_brute.ptt (the O(n^2)
// brute-force, exposed under the alias `brute`).

use tests/lib/leetcode/longest_substr
use tests/lib/leetcode/longest_substr_brute as brute

test "longest substr easy" {
  assert(longest_substr.longest("a", 1) eq 1)
  assert(longest_substr.longest("ab", 2) eq 2)
  assert(longest_substr.longest("aa", 2) eq 1)
  assert(longest_substr.longest("abc", 3) eq 3)
}

test "longest substr medium" {
  assert(longest_substr.longest("abcabcbb", 8) eq 3)
  assert(longest_substr.longest("bbbbb", 5) eq 1)
  assert(longest_substr.longest("pwwkew", 6) eq 3)
  assert(longest_substr.longest("abcdef", 6) eq 6)
  assert(longest_substr.longest("dvdf", 4) eq 3)
}

test "longest substr hard" {
  assert(longest_substr.longest("abcdefghij", 10) eq 10)
  assert(longest_substr.longest("aaaaaaaaa", 9) eq 1)
}

test "brute-force agrees with sliding-window" {
  // Both implementations should produce identical results on
  // every input.
  assert(brute.longest("abcabcbb", 8) eq longest_substr.longest("abcabcbb", 8))
  assert(brute.longest("dvdf", 4) eq longest_substr.longest("dvdf", 4))
  assert(brute.longest("pwwkew", 6) eq longest_substr.longest("pwwkew", 6))
}
