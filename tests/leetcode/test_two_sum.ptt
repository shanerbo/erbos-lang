// Two Sum tests

solve(nums list, size int, target int) int {
  through (i from 0 to size by 1) {
    through (j from i + 1 to size by 1) {
      nums[i] + nums[j] eq target ?{
        give i * 100 + j
      }
    }
  }
  give -1
}

test "two sum basic" {
  assert(solve([2, 7], 2, 9) eq 1)
  assert(solve([1, 2], 2, 3) eq 1)
  assert(solve([3, 3], 2, 6) eq 1)
}

test "two sum medium" {
  assert(solve([2, 7, 11, 15], 4, 9) eq 1)
  assert(solve([3, 2, 4], 3, 6) eq 102)
  assert(solve([1, 3, 5, 7], 4, 8) eq 3)
}

test "two sum not found" {
  assert(solve([1, 2, 3], 3, 100) eq -1)
}
