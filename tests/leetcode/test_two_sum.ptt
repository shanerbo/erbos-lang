// Two Sum tests — solve() comes from tests/lib/leetcode/two_sum.ptt
// via project-root resolution of `use tests/lib/leetcode/two_sum`.

use tests/lib/leetcode/two_sum

test "two sum basic" {
  assert(two_sum.solve([2, 7], 2, 9) eq 1)
  assert(two_sum.solve([1, 2], 2, 3) eq 1)
  assert(two_sum.solve([3, 3], 2, 6) eq 1)
}

test "two sum medium" {
  assert(two_sum.solve([2, 7, 11, 15], 4, 9) eq 1)
  assert(two_sum.solve([3, 2, 4], 3, 6) eq 102)
  assert(two_sum.solve([1, 3, 5, 7], 4, 8) eq 3)
}

test "two sum not found" {
  assert(two_sum.solve([1, 2, 3], 3, 100) eq -1)
}
