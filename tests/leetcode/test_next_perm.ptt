// Next Permutation tests — next_perm() comes from
// tests/lib/leetcode/next_perm.ptt.

use tests/lib/leetcode/next_perm

test "next perm ascending" {
  a is [1, 2, 3]
  next_perm.next_perm(a, 3)
  assert(a[0] eq 1)
  assert(a[1] eq 3)
  assert(a[2] eq 2)
}

test "next perm descending wraps" {
  a is [3, 2, 1]
  next_perm.next_perm(a, 3)
  assert(a[0] eq 1)
  assert(a[1] eq 2)
  assert(a[2] eq 3)
}

test "next perm middle" {
  a is [1, 3, 2]
  next_perm.next_perm(a, 3)
  assert(a[0] eq 2)
  assert(a[1] eq 1)
  assert(a[2] eq 3)
}
