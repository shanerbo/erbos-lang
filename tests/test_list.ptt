use std/list

test "list push and index" {
  nums is List of int
  nums.push(10)
  nums.push(20)
  nums.push(30)
  assert(nums[0] eq 10)
  assert(nums[1] eq 20)
  assert(nums[2] eq 30)
  assert(nums.len() eq 3)
}

test "list pop" {
  nums is List of int
  nums.push(1)
  nums.push(2)
  nums.push(3)
  last is nums.pop()
  assert(last eq 3)
  assert(nums.len() eq 2)
}

test "list literal" {
  // [a, b, c] still routes through the legacy `list` keyword
  // type today; phase ε3 retires that. Keep this test on the
  // legacy form to verify the bridge keeps working until then.
  nums is [10, 20, 30]
  assert(nums[0] eq 10)
  assert(nums[2] eq 30)
}

test "list growable" {
  big is List of int
  through (i from 0 to 50 by 1) {
    big.push(i)
  }
  assert(big.len() eq 50)
  assert(big[49] eq 49)
}

test "list index assign" {
  nums is List of int
  nums.push(1)
  nums.push(2)
  nums.push(3)
  nums[1] be 99
  assert(nums[1] eq 99)
}
