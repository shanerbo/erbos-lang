// Regression test: string interpolation through the IR backend.
// Verifies the NODE_STR_LIT-with-{var} handler in irgen.c plus
// the fix to the _int_to_str runtime helper (which was clobbering
// callee-save x19/x20 without saving them, fine for the direct
// codegen but a crash for the IR backend's call-aware regalloc).

use std/string

test "interpolation: single string var" {
  name is "world"
  s is "hello {name}"
  assert(s eq "hello world")
}

test "interpolation: single int var" {
  age is 42
  s is "age is {age}"
  assert(s eq "age is 42")
}

test "interpolation: mixed string + int" {
  name is "world"
  age is 42
  s is "{name} is {age}"
  assert(s eq "world is 42")
}
