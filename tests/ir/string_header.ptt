// Regression test: string literals lower to a `String` struct value.
//
// β4 layout (the layout std/string.ptt declares and codegen emits):
//
//   String header (32 bytes):
//     [0]  cap
//     [8]  count
//     [16] data ptr -> array of byte header (16 bytes)
//     [24] owned
//
//   array of byte header (16 bytes, pointed at by String.data):
//     [0]  cap
//     [8]  data ptr -> raw rodata bytes
//
// We reach into both headers via raw mem_load to confirm the codegen
// lays out the bytes the way std/string.ptt + iremit's literal emit
// agree on. Once user code uses `s.byte_at(i)` exclusively this test
// becomes redundant; until then it's the single regression that
// guards the literal layout contract.
//
// Expected output:
//   5            // String.count
//   1            // sentinel
//   104          // arr.data[0] = 'h'
//   101          // arr.data[1] = 'e'
//   108          // arr.data[2] = 'l'
//   0            // String.owned (borrowed rodata literal)

spark {
  s is "hello"
  count is mem_load(s, 8)               // String.count
  yell(count)                           // 5
  yell(1)
  arr is mem_load(s, 16)                // array of byte header ptr
  data is mem_load(arr, 8)              // raw bytes ptr
  yell(mem_load_byte(data, 0))          // 104 = 'h'
  yell(mem_load_byte(data, 1))          // 101 = 'e'
  yell(mem_load_byte(data, 2))          // 108 = 'l'
  yell(mem_load(s, 24))                 // 0
}
