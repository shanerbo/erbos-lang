use std/string

// Regression: a function compiled through the IR backend must save
// any callee-save register (x19..x28) it uses in its prologue and
// restore it in its epilogue. Otherwise a caller keeping a value in
// x19 across a `bl` to such a function loses it.
//
// We exercise this by holding a struct receiver across a call to a
// function the IR backend prefers to allocate to x19. If x19 is not
// saved, the receiver pointer is clobbered and the post-call field
// reads return garbage.

Point is {
  x int
  y int
}

bump(p Point) int {
  // Body intended to exercise arithmetic that the regalloc prefers
  // to keep in callee-save registers internally.
  give p.x + p.y
}

test "callee-save x19 preserved across call" {
  p is Point()
  p.x be 100
  p.y be 200
  assert(p.x eq 100)
  result is bump(p)
  assert(result eq 300)
  // After the call, p.x and p.y must still read correctly.
  assert(p.y eq 200)
  assert(p.x eq 100)
}
