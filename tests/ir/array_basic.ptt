// Regression test: α — `array of T` typed-storage primitive.
//
// Layout (synthesised by the compiler, never visible in source):
//   [0] cap      (int)
//   [8] data_ptr (heap-allocated slot region)
//
// User code never names heap_alloc / mem_load / mem_store —
// the compiler synthesises those calls when lowering `array of T
// with cap N` and `arr[i]` / `arr[i] be v`.
//
// Behaviour must match across -O0/-O1/-O2; the IR test runner
// runs each test at all three optimization levels.

test "array of int basic write/read" {
  xs is array of int with cap 4
  xs[0] be 10
  xs[1] be 20
  xs[2] be 30
  xs[3] be 40
  assert(xs[0] eq 10)
  assert(xs[1] eq 20)
  assert(xs[2] eq 30)
  assert(xs[3] eq 40)
}

test "array round-trip via loop variable" {
  xs is array of int with cap 4
  xs[0] be 10
  xs[1] be 20
  xs[2] be 30
  xs[3] be 40
  through (i from 0 to 4 by 1) {
    xs[i] be xs[i] + 5
  }
  assert(xs[2] eq 35)
}

test "array dynamic-cap construction" {
  big is array of int with cap 100
  big[42] be 100
  assert(big[42] eq 100)
}
