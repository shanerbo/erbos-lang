// Regression test for the P5.0 iropt scaffold: -O0, -O1, -O2 must
// all produce correct results. As P5.1+ optimization passes
// progressively shrink emitted code at -O1 and higher,
// correctness across levels is what this test guards.

use std/string

Box of T is { value T }

Box.set(self ref Box of T, v T) {
  // `v` is a non-ref borrow. For heap-shaped T we deep-clone
  // into the field via `be rep` (moving from a borrowed param
  // would be a checker error).
  self.value be rep v
}

Box.get(self Box of T) T {
  give self.value
}

test "Box of int round-trip" {
  bi is Box of int
  bi.set(42)
  assert(bi.get() eq 42)
}

test "Box of String round-trip" {
  bs is Box of String
  bs.set("hello")
  assert(bs.get() eq "hello")
}

test "loop counter visits 0..3" {
  sum is 0
  through (i from 0 to 3 by 1) {
    sum be sum + i
  }
  assert(sum eq 3)  // 0+1+2
}
