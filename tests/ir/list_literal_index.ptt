use std/string

// Regression test: list literal allocation + index access through
// the IR backend. Verifies the NODE_LIST_LIT and NODE_INDEX
// handlers in irgen.c.

use std/list

test "list literal index reads" {
  xs is [10, 20, 30]
  assert(xs[0] eq 10)
  assert(xs[1] eq 20)
  assert(xs[2] eq 30)
}

test "list literal sum across indices" {
  xs is [10, 20, 30]
  assert(xs[0] + xs[1] + xs[2] eq 60)
}
