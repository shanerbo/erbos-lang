// Regression test: collection iteration through the IR backend.
// Verifies the NODE_THROUGH_IN handler in irgen.c.

use std/list

test "through-in walks all elements + accumulates" {
  xs is [10, 20, 30]
  visited is List of int
  total is 0
  through (v in xs) {
    visited.push(v)
    total be total + v
  }
  assert(visited.len() eq 3)
  assert(visited[0] eq 10)
  assert(visited[1] eq 20)
  assert(visited[2] eq 30)
  assert(total eq 60)
}
