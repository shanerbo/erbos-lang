// Regression test: P6.0 raw memory primitives.
//
// Four functions exposed to Potato:
//   heap_alloc(size int) int       returns a pointer (held in int)
//   heap_free(p int, size int)     void
//   mem_load(p int, off int) int   *(int*)(p + off)
//   mem_store(p int, off int, v int)  *(int*)(p + off) = v
//
// These are the building blocks for pure-Potato std/list and
// std/map. Pointers are 64-bit so they fit in a Potato `int`.
//
// The IR pipeline lowers `mem_load` / `mem_store` directly to
// IR_LOAD / IR_STORE (constant offset, fast path) or an
// IR_ADD + IR_LOAD/IR_STORE pair (variable offset, general
// path). Heap calls go through `bl _heap_alloc` / `bl _heap_free`
// which already exist as runtime symbols.
//
// Output must match across -O0/-O1/-O2.
//
// Expected output:
//   42
//   100
//   7
//   9
//   900

spark {
  // Constant-offset round-trip.
  p is heap_alloc(16)
  mem_store(p, 0, 42)
  mem_store(p, 8, 100)
  yell(mem_load(p, 0))      // 42
  yell(mem_load(p, 8))      // 100

  // Variable-offset round-trip.
  off is 0
  mem_store(p, off, 7)
  off be 8
  mem_store(p, off, 9)
  off be 0
  yell(mem_load(p, off))    // 7
  off be 8
  yell(mem_load(p, off))    // 9

  heap_free(p, 16)

  // Larger allocation; loop initializes and reads via variable
  // offset. Confirms pointer arithmetic survives a loop.
  q is heap_alloc(80)       // 10 ints worth
  through (i from 0 to 10 by 1) {
    mem_store(q, i * 8, i * 20)
  }
  total is 0
  through (i from 0 to 10 by 1) {
    total be total + mem_load(q, i * 8)
  }
  yell(total)               // 20 * (0+1+..+9) = 20*45 = 900
  heap_free(q, 80)
}
