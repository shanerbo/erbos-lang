use std/string

// Regression test: P5.3 escape analysis + stack allocation
// (a.k.a. "stackify").
//
// A heap allocation whose pointer escapes the SRA promotion
// criteria can still be lowered to a stack-frame allocation if the
// pointer doesn't escape the *function*. The pointer continues to
// flow through the IR; only the storage moves from the heap to the
// stack frame, and the matched `_heap_free` is deleted.
//
// Trigger pattern: a recursive method (`bump_n`) takes the receiver
// by ref and calls itself. Inlining can't eat it (recursion guard);
// SRA can't promote (pointer passed to a call). Stackify's
// alias-set escape analysis sees the call argument is the same
// alloc'd pointer and the receiver doesn't flow outside the
// function — so the storage can live on the stack.

Counter is { value int }

Counter.bump(self ref Counter) {
  self.value be self.value + 1
}

Counter.bump_n(self ref Counter, n int) {
  n le 0 ?{
    give
  }
  self.bump()
  self.bump_n(n - 1)
}

Counter.add(self ref Counter, n int) {
  self.value be self.value + n
}

Counter.get(self Counter) int {
  give self.value
}

test "stackify: recursive bump_n" {
  // SRA can't promote (pointer passed to recursive call);
  // inlining can't (recursion guard); stackify must move
  // the heap alloc onto the stack frame.
  c is Counter()
  c.bump_n(3)
  assert(c.get() eq 3)
}

test "stackify: non-recursive add" {
  d is Counter()
  d.add(42)
  assert(d.get() eq 42)
}

test "stackify: multiple mutations on one allocation" {
  e is Counter()
  e.add(10)
  e.add(20)
  e.add(30)
  e.add(40)
  assert(e.get() eq 100)
}
