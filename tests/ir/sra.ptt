use std/string

// Regression test: P5.2 scalar replacement of aggregates (SRA).
//
// At -O1 / -O2 the SRA pass runs after inlining. For a non-escaping
// struct allocation whose pointer never leaves the function, every
// field load/store should rewrite to a shadow stack slot and the
// `_alloc_<X>` + matched `_heap_free` should be deleted.
//
// The cross-block case is the important one: after inlining, a
// struct allocated in the entry block can have its field accesses
// scattered across loop bodies and conditionals (different IR
// blocks). Per-block SRA would neuter the alloc but leave dangling
// field reads against an uninitialised slot. Function-wide SRA
// must rewrite every field access on the loaded pointer no matter
// which block holds it.

Box of T is { value T }

Box.set(self ref Box of T, v T) {
  self.value be v
}

Box.get(self Box of T) T {
  give self.value
}

Counter is { count int }

Counter.bump(self ref Counter) {
  self.count be self.count + 1
}

Counter.add(self ref Counter, n int) {
  self.count be self.count + n
}

Counter.value(self Counter) int {
  give self.count
}

Pair is {
  a int
  b int
}

test "SRA: straight-line (entry-block only)" {
  b is Box of int
  b.set(42)
  assert(b.get() eq 42)
}

test "SRA: cross-block via loop body" {
  // The alloc + STORE_LOCAL of the pointer lives in entry; the
  // inlined `c.bump()` field load/store sits inside the loop
  // body block. Function-wide SRA is required.
  c is Counter()
  through (i from 0 to 5 by 1) {
    c.bump()
  }
  assert(c.value() eq 5)
}

test "SRA: cross-block with branched arms" {
  d is Counter()
  through (j from 0 to 10 by 1) {
    j mod 2 eq 0 ?{
      d.add(2)
    } nah {
      d.add(1)
    }
  }
  // 5*2 + 5*1 = 15
  assert(d.value() eq 15)
}

test "SRA: multiple non-overlapping allocations" {
  p is Pair()
  p.a be 100
  p.b be 200
  assert(p.a eq 100)
  assert(p.b eq 200)
}
