// Regression test: string literals + collection iteration through
// the IR backend. Verifies the through-in lowering and the
// IR_LOAD_STR + string-pool data emission.

use std/string
use std/list

test "iterate List of String literals" {
  names is List of String()
  names.push("alpha")
  names.push("beta")
  names.push("gamma")

  joined is ""
  through (s in names) {
    joined be joined + s
  }
  assert(joined eq "alphabetagamma")
}
