// Regression test: enum constructors + match dispatch through the
// IR backend. Verifies the NODE_MATCH handler in irgen.c.

use std/string

Result is
  Ok(value int)
  | Err(message String)

test "match Ok arm with value" {
  r is Result.Ok(42)
  ok_v is 0
  err_seen is 0
  match r {
    Ok(v) => ok_v be v
    Err(msg) => err_seen be 1
  }
  assert(ok_v eq 42)
  assert(err_seen eq 0)
}

test "match Err arm with message" {
  r is Result.Err("oops")
  ok_seen is 0
  err_msg is ""
  match r {
    Ok(v) => ok_seen be 1
    Err(msg) => err_msg be msg
  }
  assert(ok_seen eq 0)
  assert(err_msg eq "oops")
}

test "match second Ok still routes correctly" {
  r is Result.Ok(100)
  ok_v is 0
  match r {
    Ok(v) => ok_v be v
    Err(msg) => assert(false)
  }
  assert(ok_v eq 100)
}

test "match second Err still routes correctly" {
  r is Result.Err("missing")
  err_msg is ""
  match r {
    Ok(v) => assert(false)
    Err(msg) => err_msg be msg
  }
  assert(err_msg eq "missing")
}
