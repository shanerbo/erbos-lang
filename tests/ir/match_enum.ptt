// Regression test: enum factory formation + match dispatch
// through the IR backend. Verifies the NODE_MATCH handler in
// irgen.c against values formed by the stdlib `ok`/`err`
// factories.

use std/string
use std/result

test "match Ok arm with value" {
  r is ok of int, String (42)
  ok_v is 0
  err_seen is 0
  match r {
    Ok(v) => ok_v be v
    Err(msg) => err_seen be 1
  }
  assert(ok_v eq 42)
  assert(err_seen eq 0)
}

test "match Err arm with message" {
  r is err of int, String ("oops")
  ok_seen is 0
  err_msg is ""
  match r {
    Ok(v) => ok_seen be 1
    Err(msg) => err_msg be now msg
  }
  assert(ok_seen eq 0)
  assert(err_msg eq "oops")
}

test "match second Ok still routes correctly" {
  r is ok of int, String (100)
  ok_v is 0
  match r {
    Ok(v) => ok_v be v
    Err(msg) => assert(false)
  }
  assert(ok_v eq 100)
}

test "match second Err still routes correctly" {
  r is err of int, String ("missing")
  err_msg is ""
  match r {
    Ok(v) => assert(false)
    Err(msg) => err_msg be now msg
  }
  assert(err_msg eq "missing")
}
