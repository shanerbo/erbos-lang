// Regression test: full method dispatch through the IR backend.
//
// Verifies NODE_METHOD_CALL handling in irgen:
//   - user method on a typed struct receiver lowers to
//     `_<Type>_<name>`
//   - the receiver becomes the implicit first argument
//   - return values flow back through x0

Counter is { value int }

Counter.bump(self ref Counter) {
  self.value be self.value + 1
}

Counter.set(self ref Counter, n int) {
  self.value be n
}

Counter.get(self Counter) int {
  give self.value
}

test "method dispatch: bump + get" {
  c is Counter()
  c.bump()
  assert(c.get() eq 1)
  c.bump()
  assert(c.get() eq 2)
  c.bump()
  assert(c.get() eq 3)
}

test "method dispatch: set with arg" {
  c is Counter()
  c.set(42)
  assert(c.get() eq 42)
}
