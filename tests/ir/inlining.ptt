use std/string

// Regression test: P5.1 aggressive inlining.
// At -O1 (and -O2) every `b.get()` / `b.value()` call site below
// should have its `bl _<Mangled>_<method>` replaced with the
// inlined body — a direct `ldr` of the field. At -O0 the calls
// remain. Either way the observable result must be identical.

Box of T is { value T }

Box.set(self ref Box of T, v T) {
  self.value be v
}

Box.get(self Box of T) T {
  give self.value
}

Counter is { count int }

Counter.bump(self ref Counter) {
  self.count be self.count + 1
}

Counter.value(self Counter) int {
  give self.count
}

test "inline Box.get" {
  bi is Box of int()
  bi.set(42)
  assert(bi.get() eq 42)

  bs is Box of int()
  bs.set(100)
  assert(bs.get() eq 100)
}

test "inline Counter.bump + Counter.value" {
  c is Counter()
  c.bump()
  assert(c.value() eq 1)
  c.bump()
  assert(c.value() eq 2)
  c.bump()
  assert(c.value() eq 3)
}

test "inlined value() in expression" {
  c is Counter()
  c.bump()
  c.bump()
  c.bump()
  total is c.value() + c.value()
  assert(total eq 6)
}
