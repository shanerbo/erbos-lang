// Regression test: P5.5 loop-invariant code motion (LICM).
//
// At -O1/-O2 the LICM pass identifies natural loops and hoists
// instructions whose operands are all defined outside the loop
// into the loop's pre-header. Three patterns:
//
//   1. Invariant struct-field load: SRA + stackify reduce the
//      field to a stack slot; LICM hoists the load.
//   2. Nested loops with a call inside: the call is NOT
//      hoistable but its caller-save-vs-callee-save dance is
//      what stressed two earlier bugs (cross-iter live range,
//      spill-area overlap with CSR area).
//   3. Pure-arithmetic invariant computed inside a loop body.

Box is { value int }

add(a int, b int) int { give a + b }

test "LICM: invariant field load (1 iter)" {
  b is Box()
  b.value be 100
  total is 0
  through (i from 0 to 1 by 1) { total be total + b.value }
  assert(total eq 100)
}

test "LICM: invariant field load (5 iters)" {
  // Cross-iteration live range — the hoisted vreg stays
  // resident in its register across every back-edge.
  b is Box()
  b.value be 100
  total is 0
  through (i from 0 to 5 by 1) { total be total + b.value }
  assert(total eq 500)
}

test "LICM: nested loop with call inside body" {
  sum is 0
  through (i from 0 to 4 by 1) {
    through (j from i + 1 to 4 by 1) {
      sum be sum + add(i, j)
    }
  }
  // (0+1)+(0+2)+(0+3)+(1+2)+(1+3)+(2+3) = 18
  assert(sum eq 18)
}

test "LICM: invariant arithmetic" {
  n is 10
  total is 0
  through (i from 0 to 5 by 1) { total be total + (n + 2) }
  assert(total eq 60)
}
