// Regression test: P5.5 loop-invariant code motion (LICM).
//
// At -O1/-O2 the LICM pass identifies natural loops (back-edges
// targeting earlier blocks) and hoists every instruction whose
// operands are all defined outside the loop to the loop's
// pre-header. The pre-header is the unique block whose terminator
// is an unconditional branch to the loop header.
//
// Three patterns to verify here:
//
//   1. Single-loop invariant local-load: reading a struct field
//      every iteration of a loop where neither the struct pointer
//      nor the field is mutated. After SRA + stackify, the
//      remaining IR_LOAD reads from a stack-frame address; LICM
//      hoists it to the pre-header so the body becomes a single
//      add against a register.
//
//   2. Nested loops with a function call inside: the call is NOT
//      hoistable (CALL has side effects), but the call's
//      arguments — if all loop-invariant — should be set up once
//      per outer iteration in the inner pre-header. The total
//      sum below stresses the call's caller-save-vs-callee-save
//      register-allocation path that LICM exposes; that path was
//      where two earlier bugs surfaced (cross-iteration live
//      range, spill-area overlap with CSR area).
//
//   3. Pure-arithmetic invariant: a constant computed inside a
//      loop body that depends only on outer-defined values.
//      LICM should fold it out to the pre-header at -O1.
//
// All three levels must produce identical observable output.
//
// Expected output:
//   100         // pattern 1: 1 * 100 (one loop iter for clarity)
//   500         // pattern 1 again, 5 iters
//   18          // pattern 2: nested 4-element triangle of i+j sums
//   60          // pattern 3: 5 iterations of (10 + 2)

Box is { value int }

add(a int, b int) int { give a + b }

spark {
  // Pattern 1: invariant field load through a non-escaping struct.
  // After SRA + stackify the field becomes a stack slot; LICM
  // hoists the load out of the loop.
  b is Box()
  b.value be 100
  total is 0
  through (i from 0 to 1 by 1) { total be total + b.value }
  yell(total)             // 100

  // Same shape, more iterations — exercises the cross-iteration
  // live range fix (the hoisted vreg must stay in its register
  // across every back-edge).
  total2 is 0
  through (i from 0 to 5 by 1) { total2 be total2 + b.value }
  yell(total2)            // 500

  // Pattern 2: nested loop with a call. The call is the path
  // that previously regressed when LICM was first added.
  sum is 0
  through (i from 0 to 4 by 1) {
    through (j from i + 1 to 4 by 1) {
      sum be sum + add(i, j)
    }
  }
  yell(sum)               // (0+1)+(0+2)+(0+3)+(1+2)+(1+3)+(2+3) = 18

  // Pattern 3: invariant arithmetic. `n + 2` is invariant for
  // the loop; LICM hoists the add to the pre-header.
  n is 10
  total3 is 0
  through (i from 0 to 5 by 1) { total3 be total3 + (n + 2) }
  yell(total3)            // 60
}
