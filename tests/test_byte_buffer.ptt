use std/string
use std/byte_buffer

test "fresh ByteBuffer is empty" {
  b is ByteBuffer()
  assert(b.empty())
  assert(b.len() eq 0)
  assert(b.cap() eq 0)
}

test "push and get round-trip bytes including zero" {
  b is ByteBuffer()
  b.push(0)
  b.push(65)
  b.push(255)
  assert(b.get(0) eq 0)
  assert(b.get(1) eq 65)
  assert(b.get(2) eq 255)
}

test "set overwrites existing bytes" {
  b is ByteBuffer()
  b.push(65)
  b.push(66)
  b.set(1, 90)
  assert(b.get(0) eq 65)
  assert(b.get(1) eq 90)
}

test "extend appends another buffer in order" {
  a is ByteBuffer()
  a.push(65)
  a.push(66)
  b is ByteBuffer()
  b.push(67)
  b.push(68)
  a.extend(b)
  assert(a.len() eq 4)
  assert(a.get(0) eq 65)
  assert(a.get(3) eq 68)
}

test "slice returns an independent byte range" {
  b is ByteBuffer()
  b.push(65)
  b.push(66)
  b.push(67)
  mid is b.slice(1, 3)
  assert(mid.len() eq 2)
  assert(mid.get(0) eq 66)
  assert(mid.get(1) eq 67)
}

test "to_string converts ASCII bytes" {
  b is ByteBuffer()
  b.push(112)
  b.push(111)
  b.push(116)
  assert(b.to_string().equals("pot"))
}

test "clear empties buffer and keeps capacity" {
  b is ByteBuffer()
  b.push(1)
  b.push(2)
  before is b.cap()
  b.clear()
  assert(b.empty())
  assert(b.cap() eq before)
  b.push(3)
  assert(b.get(0) eq 3)
}

test "reserve preallocates and growth still works" {
  b is ByteBuffer()
  b.reserve(32)
  assert(b.cap() eq 32)
  through (i from 0 to 20 by 1) {
    b.push(65 + i)
  }
  assert(b.len() eq 20)
}
