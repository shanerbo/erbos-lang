// Leetcode 1: Two Sum
// Approach: O(n^2) brute force
// Time: O(n^2)  Space: O(1)
// Output: i*100+j encoding (e.g. 001 = indices 0,1)

use std/list

solve(nums List of int, size int, target int) int {
  through (i from 0 to size by 1) {
    through (j from i + 1 to size by 1) {
      nums[i] + nums[j] eq target ?{
        give i * 100 + j
      }
    }
  }
  give -1
}
