// Leetcode 994: Rotting Oranges
// BFS approach
// Time: O(rows * cols)  Space: O(rows * cols)
//
// Grid values: 0=empty, 1=fresh, 2=rotten
// Each minute, rotten spreads to adjacent fresh oranges
// Return minutes until no fresh remain, or -1 if impossible

// Encode (row, col) as row*100+col for queue storage
// Grid is flattened: grid[row*cols + col]

use std/list

solve(grid List of int, rows int, cols int) int {
  // Queue: list of encoded positions
  queue is List of int()
  fresh is 0

  // Find initial rotten and count fresh
  through (r from 0 to rows by 1) {
    through (c from 0 to cols by 1) {
      idx is r * cols + c
      grid[idx] eq 2 ?{
        queue.push(r * 100 + c)
      }
      grid[idx] eq 1 ?{
        fresh be fresh + 1
      }
    }
  }

  fresh eq 0 ?{ give 0 }

  minutes is 0
  head is 0
  // Directions: up, down, left, right
  dr is [0 - 1, 1, 0, 0]
  dc is [0, 0, 0 - 1, 1]

  infi (head lt queue.len()) {
    size is queue.len() - head
    through (s from 0 to size by 1) {
      pos is queue[head]
      head be head + 1
      r is pos / 100
      c is pos mod 100

      through (d from 0 to 4 by 1) {
        nr is r + dr[d]
        nc is c + dc[d]
        nr ge 0 and nr lt rows and nc ge 0 and nc lt cols ?{
          nidx is nr * cols + nc
          grid[nidx] eq 1 ?{
            grid[nidx] be 2
            queue.push(nr * 100 + nc)
            fresh be fresh - 1
          }
        }
      }
    }
    fresh eq 0 ?{ give minutes + 1 }
    minutes be minutes + 1
  }

  give -1
}
