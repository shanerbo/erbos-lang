use std/string

test "string interpolation int" {
  x is 42
  msg is "val is {x}"
  assert(msg.len() gt 0)
}

test "string concat" {
  a is "hello"
  b is " world"
  c is a + b
  n is c.len()
  assert(n eq 11)
}

test "len" {
  assert("hello".len() eq 5)
  assert("".len() eq 0)
}

test "char_at" {
  s is "abcdef"
  c is s.char_at(0)
  assert(c eq "a")
  d is s.char_at(3)
  assert(d eq "d")
}
