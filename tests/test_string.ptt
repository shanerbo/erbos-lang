test "string interpolation int" {
  x is 42
  msg is "val is {x}"
  assert(len(msg) gt 0)
}

test "string concat" {
  a is "hello"
  b is " world"
  c is a + b
  n is str_len(c)
  assert(n eq 11)
}

test "str_len" {
  assert(str_len("hello") eq 5)
  assert(str_len("") eq 0)
}

test "char_at" {
  s is "abcdef"
  c is char_at(s, 0)
  assert(c eq "a")
  d is char_at(s, 3)
  assert(d eq "d")
}

test "len on string" {
  assert(len("hello") eq 5)
  assert(len("") eq 0)
}
