// Microbenchmark for Map of String, int set/get/keys.
//
// This is the post-overhaul reference for `Map of String, int`
// (pure-Potato, backed by `array of T`). It supersedes the
// pre-overhaul baseline that measured the C-emitted `_map_*`
// helpers; θ4 captures the wall-clock comparison externally.
//
// Phases:
//   1. set: insert N distinct keys.
//   2. get: read every key back (forces every bucket walk).
//   3. keys: enumerate the map and sum the values.
//
// N=512 is small enough for the test suite (sub-second at any
// -O level) but large enough that the loop dominates any fixed
// setup cost.

use std/string
use std/list
use std/map

spark {
  m is Map of String, int()

  // Phase 1: set 512 distinct keys.
  through (i from 0 to 512 by 1) {
    k is "k{i}"
    m.set(k, i * 7)
  }
  yell(m.len())                         // 512 — confirms inserts done

  // Phase 2: read every key back; sum the values to keep the
  // compiler from dead-code-eliminating the loads.
  total is 0
  through (i from 0 to 512 by 1) {
    k is "k{i}"
    total be total + m.get(k)
  }
  yell(total)                           // 7 * (511*512/2) = 915712

  // Phase 3: enumerate keys and sum values via lookup.
  ks is m.keys()
  ksum is 0
  through (k in ks) {
    ksum be ksum + m.get(k)
  }
  yell(ksum)                            // same as total: 915712
}
