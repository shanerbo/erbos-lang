// User-defined methods on user types (P0 spike + P1 productionisation).
//
// Covers:
//   - method definitions parse: `Type.name(self [ref] Type, ...)`
//   - void / parameterised / value-returning methods
//   - methods on structs, methods on enums
//   - per-instance state isolation
//   - methods that return their owning type (Point -> Point)
//   - recursive method calls through self
//   - methods called inside loops

use std/string
use std/result

Counter is {
  value int
}

Counter.bump(self ref Counter) {
  self.value be self.value + 1
}

Counter.add(self ref Counter, n int) {
  self.value be self.value + n
}

Counter.get(self Counter) int {
  give self.value
}

Counter.bump_n(self ref Counter, n int) {
  n le 0 ?{
    give
  }
  self.value be self.value + 1
  self.bump_n(n - 1)
}

Point is {
  x int
  y int
}

Point.translated(self Point, dx int, dy int) Point {
  p is Point()
  p.x be self.x + dx
  p.y be self.y + dy
  give p
}

// Method dispatch on enum receivers — exercised via the
// stdlib `Result of T, E` enum. User-defined enums have no
// value-formation syntax under the new language law (only the
// stdlib factories `none`, `some`, `ok`, `err` form values),
// so methods on user enums can't be tested without first
// adding a factory function for them. The point of this case
// is method-symbol resolution on an enum-typed receiver, which
// `Result` covers fine.

Result.tag(self Result of int, String) int {
  give 99
}

test "user methods: void mutator" {
  c is Counter()
  c.bump()
  c.bump()
  c.bump()
  assert(c.get() eq 3)
}

test "user methods: parameterised mutator" {
  c is Counter()
  c.add(10)
  c.add(32)
  assert(c.get() eq 42)
}

test "user methods: multiple instances are independent" {
  a is Counter()
  b is Counter()
  a.bump()
  a.bump()
  b.bump()
  assert(a.get() eq 2)
  assert(b.get() eq 1)
}

test "user methods: recursion through self" {
  c is Counter()
  c.bump_n(50)
  assert(c.get() eq 50)
}

test "user methods: called inside a loop" {
  c is Counter()
  through (i from 0 to 100 by 1) {
    c.bump()
  }
  assert(c.get() eq 100)
}

test "user methods: returning the owning struct type" {
  origin is Point()
  origin.x be 10
  origin.y be 20
  shifted is origin.translated(5, 7)
  assert(shifted.x eq 15)
  assert(shifted.y eq 27)
}

test "user methods: methods on enum receivers" {
  r is ok of int, String (42)
  assert(r.tag() eq 99)
}
