// Regression for spudlock issue #11: match-arm bindings need
// their declared types so method dispatch on them resolves to
// the right symbol.
//
// Pre-fix, the checker never visited NODE_MATCH at all. Match
// arm bindings ran through irgen + emit but had no type, so a
// method call like `count.to_string()` inside an arm fell to
// the unknown-receiver path and emitted bare `bl _to_string`
// (undefined). Spudlock's report.ptt hit this exactly.

use std/string
use std/result

format_result(r Result of int, String) String {
  match r {
    Ok(v) => give "ok " + v.to_string()
    Err(m) => give "error " + ": " + m
  }
  give ""
}

test "match Ok arm binds int to use to_string()" {
  r is ok of int, String (42)
  s is format_result(r)
  assert(s.equals("ok 42"))
}

test "match Err arm binds String correctly" {
  r is err of int, String ("boom")
  s is format_result(r)
  assert(s.equals("error : boom"))
}

test "match arm method dispatch picks the right symbol per type" {
  // Stress: int.to_string() and String passed unchanged in same
  // arm. Without the binding-type fix, v was treated as having
  // unknown type and method dispatch fell back to a bare call.
  r is ok of int, String (99)
  match r {
    Ok(v) => assert(v.to_string().equals("99"))
    Err(m) => assert(false)
  }
}
