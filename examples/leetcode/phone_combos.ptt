// Leetcode 17: Letter Combinations of a Phone Number
// Approach: Recursive backtracking
// Time: O(4^n)  Space: O(n)

use std/string

get_letters(digit String) String {
  digit eq "2" ?{ give "abc" }
  digit eq "3" ?{ give "def" }
  digit eq "4" ?{ give "ghi" }
  digit eq "5" ?{ give "jkl" }
  digit eq "6" ?{ give "mno" }
  digit eq "7" ?{ give "pqrs" }
  digit eq "8" ?{ give "tuv" }
  digit eq "9" ?{ give "wxyz" }
  give ""
}

backtrack(digits String, index int, current String, n int) {
  index eq n ?{
    yell(current)
    give
  }
  digit is digits.char_at(index)
  letters is get_letters(digit)
  num_letters is letters.len()
  through (i from 0 to num_letters by 1) {
    ch is letters.char_at(i)
    next is current + ch
    backtrack(digits, index + 1, next, n)
  }
}

solve(digits String) {
  n is digits.len()
  n eq 0 ?{ give }
  backtrack(digits, 0, "", n)
}

spark {
  // Easy: single digit
  solve("2")
  yell("---")
  solve("9")
  yell("---")

  // Medium: two digits
  solve("23")
  yell("---")
  solve("79")
  yell("---")
  solve("45")
  yell("---")

  // Hard: three digits
  solve("234")
}
