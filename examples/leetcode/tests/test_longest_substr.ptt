// Longest Substring Without Repeating Characters tests

use std/string
use std/map

longest(s String, n int) int {
  seen is Map of String to int
  start is 0
  max_len is 0
  through (i from 0 to n by 1) {
    ch is s.char_at(i)
    prev is seen.get(ch)
    prev ne 0 ?{
      prev - 1 ge start ?{
        start be prev
      }
    }
    cur is i - start + 1
    cur gt max_len ?{ max_len be cur }
    seen.set(ch, i + 1)
  }
  give max_len
}

test "longest substr easy" {
  assert(longest("a", 1) eq 1)
  assert(longest("ab", 2) eq 2)
  assert(longest("aa", 2) eq 1)
  assert(longest("abc", 3) eq 3)
}

test "longest substr medium" {
  assert(longest("abcabcbb", 8) eq 3)
  assert(longest("bbbbb", 5) eq 1)
  assert(longest("pwwkew", 6) eq 3)
  assert(longest("abcdef", 6) eq 6)
  assert(longest("dvdf", 4) eq 3)
}

test "longest substr hard" {
  assert(longest("abcdefghij", 10) eq 10)
  assert(longest("aaaaaaaaa", 9) eq 1)
}
