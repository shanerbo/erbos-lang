// Rotting Oranges tests

use std/list

solve(grid List of int, rows int, cols int) int {
  queue is List of int
  fresh is 0
  through (r from 0 to rows by 1) {
    through (c from 0 to cols by 1) {
      idx is r * cols + c
      grid[idx] eq 2 ?{ queue.push(r * 100 + c) }
      grid[idx] eq 1 ?{ fresh be fresh + 1 }
    }
  }
  fresh eq 0 ?{ give 0 }
  minutes is 0
  head is 0
  dr is [0 - 1, 1, 0, 0]
  dc is [0, 0, 0 - 1, 1]
  infi (head lt queue.len()) {
    size is queue.len() - head
    through (s from 0 to size by 1) {
      pos is queue[head]
      head be head + 1
      r is pos / 100
      c is pos mod 100
      through (d from 0 to 4 by 1) {
        nr is r + dr[d]
        nc is c + dc[d]
        nr ge 0 and nr lt rows and nc ge 0 and nc lt cols ?{
          nidx is nr * cols + nc
          grid[nidx] eq 1 ?{
            grid[nidx] be 2
            queue.push(nr * 100 + nc)
            fresh be fresh - 1
          }
        }
      }
    }
    fresh eq 0 ?{ give minutes + 1 }
    minutes be minutes + 1
  }
  give -1
}

test "rotting oranges basic" {
  assert(solve([2,1,1, 1,1,0, 0,1,1], 3, 3) eq 4)
  assert(solve([0, 2], 1, 2) eq 0)
  assert(solve([2], 1, 1) eq 0)
}

test "rotting oranges unreachable" {
  assert(solve([2,1,1, 0,1,1, 1,0,1], 3, 3) eq -1)
  assert(solve([1], 1, 1) eq -1)
}

test "rotting oranges multi source" {
  assert(solve([2,1,1, 1,1,1, 0,1,2], 3, 3) eq 2)
  assert(solve([2,2, 1,1], 2, 2) eq 1)
}
