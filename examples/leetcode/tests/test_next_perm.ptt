// Next Permutation tests

use std/list

swap(nums List of int, i int, j int) {
  tmp is nums[i]
  nums[i] be nums[j]
  nums[j] be tmp
}

reverse(nums List of int, start int, end int) {
  l is start
  r is end
  infi (l lt r) {
    swap(nums, l, r)
    l be l + 1
    r be r - 1
  }
}

next_perm(nums List of int, n int) {
  i is n - 2
  infi (i ge 0) {
    nums[i] lt nums[i + 1] ?{ stop }
    i be i - 1
  }
  i ge 0 ?{
    j is n - 1
    infi (j gt i) {
      nums[j] gt nums[i] ?{ stop }
      j be j - 1
    }
    swap(nums, i, j)
  }
  reverse(nums, i + 1, n - 1)
}

test "next perm ascending" {
  a is [1, 2, 3]
  next_perm(a, 3)
  assert(a[0] eq 1)
  assert(a[1] eq 3)
  assert(a[2] eq 2)
}

test "next perm descending wraps" {
  a is [3, 2, 1]
  next_perm(a, 3)
  assert(a[0] eq 1)
  assert(a[1] eq 2)
  assert(a[2] eq 3)
}

test "next perm middle" {
  a is [1, 3, 2]
  next_perm(a, 3)
  assert(a[0] eq 2)
  assert(a[1] eq 1)
  assert(a[2] eq 3)
}
