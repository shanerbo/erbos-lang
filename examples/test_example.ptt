add(a int, b int) int {
  give a + b
}

fib(n int) int {
  n le 1 ?{ give n }
  give fib(n - 1) + fib(n - 2)
}

test "addition" {
  assert(add(1, 2) eq 3)
  assert(add(0, 0) eq 0)
  assert(add(-1, 1) eq 0)
}

test "fibonacci" {
  assert(fib(0) eq 0)
  assert(fib(1) eq 1)
  assert(fib(5) eq 5)
  assert(fib(10) eq 55)
}

test "comparisons" {
  assert(5 gt 3)
  assert(3 lt 5)
  assert(5 eq 5)
  assert(5 ne 4)
}

test "list operations" {
  nums is list of int
  nums.push(10)
  nums.push(20)
  assert(len(nums) eq 2)
  assert(nums[0] eq 10)
  assert(nums[1] eq 20)
}
