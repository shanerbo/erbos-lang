{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Erbos",
  "scopeName": "source.ptt",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#methods" },
    { "include": "#functions" },
    { "include": "#structs" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ptt",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ptt",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ptt",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "variable.other.interpolation.ptt",
              "match": "\\{[a-zA-Z_][a-zA-Z0-9_]*\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ptt",
          "match": "-?\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ptt",
          "match": "\\b(spark|give|through|from|to|by|in|infi|stop|skip|nah|match|test)\\b"
        },
        {
          "name": "keyword.declaration.ptt",
          "match": "\\b(is|be|nomut|now|rep|ref|use|as|of|with|cap)\\b"
        },
        {
          "name": "keyword.operator.logical.ptt",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.comparison.ptt",
          "match": "\\b(eq|ne|gt|lt|ge|le|mod)\\b"
        },
        {
          "name": "constant.language.boolean.ptt",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ptt",
          "match": "(\\?\\{|=>|==|!=|>=|<=|>|<|\\+|-|\\*|/|%)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.ptt",
          "match": "\\b(int|bool|byte|void|array|task)\\b"
        },
        {
          "name": "support.class.stdlib.ptt",
          "match": "\\b(String|List|Map|StringMap)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.ptt",
          "match": "\\b(yell|assert)\\b"
        }
      ]
    },
    "methods": {
      "patterns": [
        {
          "comment": "Highlight known stdlib method names when called via the .method() syntax. Catches the common surface (push/pop/get/set/len/keys/byte_at/char_at/to_string/equals/empty/concat) without false-positive on user-defined methods that happen to share names.",
          "name": "support.function.method.ptt",
          "match": "(?<=\\.)\\b(push|pop|get|set|keys|len|byte_at|char_at|to_string|equals|empty|concat|yell|fire|collapse)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.ptt",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "structs": {
      "patterns": [
        {
          "name": "entity.name.type.ptt",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    }
  }
}
