{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Erbos",
  "scopeName": "source.erbos",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#structs" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.erbos",
          "match": "//.*$"
        },
        {
          "name": "comment.block.erbos",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.erbos",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "variable.other.interpolation.erbos",
              "match": "\\{[a-zA-Z_][a-zA-Z0-9_]*\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.erbos",
          "match": "-?\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.erbos",
          "match": "\\b(spark|give|through|from|to|by|in|infi|stop|skip|nah)\\b"
        },
        {
          "name": "keyword.declaration.erbos",
          "match": "\\b(is|be|nomut|now|rep|ref)\\b"
        },
        {
          "name": "keyword.operator.logical.erbos",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.comparison.erbos",
          "match": "\\b(eq|ne|gt|lt|ge|le|mod)\\b"
        },
        {
          "name": "constant.language.boolean.erbos",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.erbos",
          "match": "(\\?\\{|==|!=|>=|<=|>|<|\\+|-|\\*|/|%)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.erbos",
          "match": "\\b(int|str|bool|void|list|map|task|of)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.erbos",
          "match": "\\b(yell|len|str_concat)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.erbos",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "structs": {
      "patterns": [
        {
          "name": "entity.name.type.erbos",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    }
  }
}
