// Queue: FIFO data structure using a list + head pointer.

use std/list

new() List of int {
  give List of int
}

push(q List of int, val int) {
  q.push(val)
}

pop(q List of int, head int) int {
  give q[head]
}

size(q List of int, head int) int {
  give q.len() - head
}

empty(q List of int, head int) int {
  q.len() - head le 0 ?{ give 1 }
  give 0
}
