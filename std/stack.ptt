// Stack: LIFO data structure using a list.

use std/list

new() List of int {
  give List of int
}

push(s List of int, val int) {
  s.push(val)
}

pop(s List of int) int {
  give s.pop()
}

peek(s List of int) int {
  give s[s.len() - 1]
}

size(s List of int) int {
  give s.len()
}

empty(s List of int) int {
  s.len() eq 0 ?{ give 1 }
  give 0
}
